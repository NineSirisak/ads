# =============================================================================
# CKTONLINE — Environment Variables (คัดลอกเป็น .env.local ตอน dev)
# ตอน deploy บน Vercel: ใส่ที่ Project Settings → Environment Variables
# =============================================================================

# --- Supabase (จำเป็น) --------------------------------------------------------
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...anon-key...
# ⚠️ SERVICE_ROLE_KEY = ห้ามเปิด public / ห้ามใส่ NEXT_PUBLIC_ prefix
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...service-role...

# --- LINE Messaging API (สำหรับ notification) --------------------------------
LINE_CHANNEL_ACCESS_TOKEN=
LINE_LOGIN_CHANNEL_ID=
LINE_LOGIN_REDIRECT_URI=https://your-domain.vercel.app/api/notify/line/link

# --- Internal secret (ป้องกัน cron endpoint ถูกเรียกจากภายนอก) ----------------
# สร้างด้วย: openssl rand -hex 32
INTERNAL_DISPATCH_SECRET=
